<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@color/Background"
    android:layout_height="match_parent"
    tools:context=".ContactFragment">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contact_nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_button_background"
            android:padding="10sp"
            android:layout_gravity="center"
            android:layout_margin="10sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_contact_details_title"
                android:layout_width="0sp"
                android:layout_height="wrap_content"
                android:text="Contact Details"
                android:textColor="#345DDA"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                android:layout_marginBottom="16sp"
                android:layout_marginTop="10sp" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0sp"
                android:layout_height="wrap_content"
                android:text="@string/awadhesh"
                android:textColor="#000000"
                android:textSize="20sp"
                app:layout_constraintTop_toBottomOf="@id/tv_contact_details_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.5"
                android:layout_marginBottom="16sp"
                android:layout_marginTop="30sp" />

            <TextView
                android:id="@+id/personal_phone_1"
                android:layout_width="0sp"
                android:layout_height="wrap_content"
                android:text="+91 8579909138"
                android:textSize="18sp"
                android:textColor="#666666"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_phone"
                app:layout_constraintHorizontal_bias="0.5"
                android:layout_marginBottom="16sp"
                android:layout_marginTop="30sp"
                android:layout_marginEnd="16sp"/>

            <ImageButton
                android:id="@+id/btn_phone"
                android:layout_width="48sp"
                android:layout_height="48sp"
                android:layout_marginEnd="20sp"
                android:background="@drawable/mobile_number_icon"
                app:layout_constraintBottom_toBottomOf="@id/personal_phone_1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/personal_phone_1"
                app:layout_constraintVertical_bias="0.541" />

            <TextView
                android:id="@+id/personal_phone_2"
                android:layout_width="0sp"
                android:layout_height="wrap_content"
                android:text="+91 9162766127"
                android:textSize="18sp"
                android:textColor="#666666"
                app:layout_constraintTop_toBottomOf="@id/personal_phone_1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_whatsapp"
                app:layout_constraintHorizontal_bias="0.5"
                android:layout_marginBottom="16sp"
                android:layout_marginTop="30sp"
                android:layout_marginEnd="16sp"/>

            <ImageButton
                android:id="@+id/btn_whatsapp"
                android:layout_width="57sp"
                android:layout_height="57sp"
                android:layout_marginEnd="14sp"
                android:background="@drawable/icon_whatsapp"
                app:layout_constraintBottom_toBottomOf="@id/personal_phone_2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/personal_phone_2"
                app:layout_constraintVertical_bias="0.233" />

            <TextView
                android:id="@+id/tv_gst_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GST No:"
                android:textColor="#000000"
                android:textSize="17sp"
                app:layout_constraintTop_toBottomOf="@id/personal_phone_2"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginEnd="8sp"
                android:layout_marginTop="30sp" />

            <TextView
                android:id="@+id/tv_gst_number"
                android:layout_width="0sp"
                android:layout_height="wrap_content"
                android:text="@string/gst"
                android:textSize="16sp"
                android:textColor="#666666"
                app:layout_constraintTop_toBottomOf="@id/personal_phone_2"
                app:layout_constraintStart_toEndOf="@id/tv_gst_label"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="8sp"
                android:layout_marginTop="30sp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>