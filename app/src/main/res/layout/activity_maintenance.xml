<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".LoadingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">


        <ImageView
            android:id="@+id/splash_logo"
            android:layout_width="250dp"
            android:layout_height="325dp"
            android:src="@drawable/akashjewllers"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ This app is under maintenance.\nPlease try again later."
             android:textSize="17sp"
            android:textColor="@color/black"
            >

        </TextView>
        <ProgressBar
            android:id="@+id/splash_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp" />


    </LinearLayout>

    <TextView
        android:id="@+id/developer_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/Developed"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:textSize="12sp" android:textColor="#FF808080"
        tools:text="Developed by Your Name" />

</RelativeLayout>